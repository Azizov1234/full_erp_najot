# Port configuration
PORT=3900

# Prisma connection string (PostgreSQL database)
DATABASE_URL="postgresql://postgres:password@localhost:5432/crm_db?schema=public"

# Redis Configuration (Optional, fallback to in-memory is implemented)
# REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Supabase Storage Configuration
SUPABASE_URL=
SUPABASE_KEY=

# Superadmin Seeder Credentials
SUPERADMIN_PHONE=
SUPERADMIN_PASSWORD=
